# Copy this file to .env.local and fill in the values you need.
# .env.local is gitignored; .env (tracked) holds only non-secret defaults.

# Sentry DSN for frontend error reporting. Leave unset in dev/local to make
# Sentry a no-op. The DSN itself is not a secret (Sentry DSNs are public by
# design and embedded in client bundles), but we keep it out of the tracked
# .env so different environments can use different projects.
VITE_SENTRY_DSN=

# ─── Playwright E2E (see tests/e2e/README.md) ───
# Override the target the tests run against. Unset → tests start a local
# Vite dev server and hit http://localhost:8080. Set to https://junto.pro
# (or another env) to run smoke tests against a deployed instance.
TEST_BASE_URL=

# Persistent test user. Required only for tests that need a stable
# pre-existing account (the signup test creates its own users).
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Service-role key for the Supabase project, used ONLY for cleaning up
# test users/trips after each run. Never commit this. Leave unset locally
# if you don't mind a few orphan test rows accumulating.
TEST_SUPABASE_SERVICE_ROLE_KEY=
